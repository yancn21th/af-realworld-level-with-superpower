meta {
  name: Update article: tagList null should be rejected
  type: http
  seq: 15
}

put {
  url: {{host}}/api/articles/{{slug}}
  body: json
  auth: none
}

headers {
  Authorization: Token {{token}}
}

body:json {
  {
    "article": {
      "tagList": null
    }
  }
}

assert {
  res.status: eq 422
}
